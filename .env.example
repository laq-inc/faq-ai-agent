POSTGRES_DB=db
POSTGRES_USER=userp
POSTGRES_HOST=host
POSTGRES_PORT=port
POSTGRES_CONNECT_TIMEOUT=5

OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=your_openai_embedding_model
OPENAI_CHAT_MODEL=your_openai_chat_model
OPENAI_TIMEOUT=30

# Set the token obtained by running `claude setup-token` on the host
CLAUDE_CODE_OAUTH_TOKEN=your_claude_code_oauth_token

# One-time setup: to prevent the initial setup dialog (theme selection /
# folder trust) from appearing every time inside the container, run once:
#   cp .devcontainer/claude-home/claude.json.example .devcontainer/claude-home/claude.json